__pycache__/
.claude/settings.local.json
.claude/auto-push.sh

# Frontend build dependencies. The build artifact static/dist/main.js
# IS committed so Railway deploys without needing a Node toolchain;
# only node_modules and TS build cache are ignored.
node_modules/
*.tsbuildinfo

# Third-party reference docs (FL API PDF, OpenAPI spec, etc.) —
# useful to have locally for cross-reference during dev, but not
# tracked in git. Re-download from RapidAPI / HugeAPI if needed.
*.pdf
fl-openapi.json
