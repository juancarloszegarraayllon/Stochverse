# Local development environment for the SP Architecture rebuild.
# Copy to .env and fill in real values; .env is gitignored.

# ── Database ───────────────────────────────────────────────────
# Local stack via docker-compose:
DATABASE_URL=postgresql+asyncpg://dev:dev@localhost:5432/sports_dev

# ── Logging ────────────────────────────────────────────────────
# Default is JSON output for Railway. Set to 'console' for
# human-readable colored output during local development.
STOCHVERSE_LOG_FORMAT=console

# ── Provider keys (for local-against-real-providers testing) ──
FLASHLIVE_API_KEY=
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY=
ODDSAPI_KEY=
POLYMARKET_API_KEY=

# ── Worker concurrency (Phase 0; production is set in Railway) ─
# Local dev runs single-worker by default; production should set
# this to 2+ in the Railway dashboard per DEPLOYMENT.md.
WEB_CONCURRENCY=1
